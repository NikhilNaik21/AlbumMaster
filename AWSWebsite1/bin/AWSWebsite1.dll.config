<configuration>
	<system.web>
		<customErrors mode="Off"/>
		<compilation debug="true"/>
		<globalization culture="en-US" uiCulture="en-US"/>
		<httpRuntime targetFramework="4.6" maxRequestLength="51200" executionTimeout="3600"/>

	</system.web>
	<connectionStrings>
		<add name="AWSDemoDB" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=AlbumManagementDB;User ID=sa;Password=YourStrongPass123!;Integrated Security=False;"/>
	</connectionStrings>
	<appSettings>
		<add key="AlbumPhotoPath" value="/AlbumPhotos/"/>
		<add key="ProfileImagePath" value="/ProfileImages/"/>
		<add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />

		<add key="AWS_AccessKey" value="AKIAW44H4G5GMZFGGXZ5"/>
		<add key="AWS_SecretKey" value="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"/>
	</appSettings>
	<system.webServer>
		<httpErrors errorMode="Detailed"/>
		<security>
			<requestFiltering>
				<!--  50MB in bytes  -->
				<requestLimits maxAllowedContentLength="52428800"/>
			</requestFiltering>
		</security>
		<!--  VERY IMPORTANT  -->
		<handlers>
			<add name="UploadHandler" path="UploadHandler.ashx" verb="*" type="AWSWebsite1.UploadHandler" resourceType="Unspecified"/>
		</handlers>
	</system.webServer>
</configuration>